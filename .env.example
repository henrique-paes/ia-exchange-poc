# Postgres (used by docker-compose)
POSTGRES_USER=library
POSTGRES_PASSWORD=library
POSTGRES_DB=library

# Host ports (container ports are fixed: backend 3000, frontend 5173).
# Backend defaults to 3001 to avoid clashing with other local dev servers on 3000.
BACKEND_PORT=3001
FRONTEND_PORT=5173

# CORS: origin allowed to call the API (the frontend). Compose derives it
# from FRONTEND_PORT; override here if the frontend runs elsewhere.
CORS_ORIGIN=http://localhost:5173
